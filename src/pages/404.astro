---
import SiteShell from "@/layouts/SiteShell.astro";

const base = import.meta.env.BASE_URL;
const href = (pathname = "") => `${base}${pathname.replace(/^\/+/, "")}`;
---

<SiteShell title="Page not found" description="The requested page could not be found.">
  <section class="container not-found" aria-labelledby="not-found-title">
    <p class="code">404</p>
    <h1 id="not-found-title" class="title-serif">Page not found</h1>
    <p class="hint">The requested page could not be found. It may have moved, or the address may be mistyped.</p>
    <nav aria-label="Helpful links">
      <a href={href()}>Home</a>
      <a href={href("course-notes/")}>Course notes</a>
      <a href={href("paper-reading/")}>Paper reading</a>
    </nav>
  </section>
</SiteShell>

<style>
  .not-found {
    display: grid;
    min-height: 55vh;
    align-content: center;
    justify-items: start;
    gap: 0.9rem;
    padding-block: 3rem;
  }

  .code {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    line-height: 1.05;
  }

  .hint {
    margin: 0;
    max-width: 46ch;
    color: var(--muted);
    line-height: 1.65;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin-top: 0.8rem;
  }

  nav a {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    padding-bottom: 0.1rem;
    transition: border-color 140ms ease;
  }

  nav a:hover {
    border-bottom-color: var(--accent);
  }
</style>
