---
import { learningMapNodes } from "@/data/learning-map";
---

<section class="topics rise" aria-labelledby="topics-title" style="--rise-order: 3;">
  <h2 class="sr-only" id="topics-title">Topics</h2>
  <p class="prompt-line" aria-hidden="true"><span class="prompt">$</span> <span class="cmd">tree topics/</span></p>
  <div class="tree">
    <p class="tree-root" aria-hidden="true">topics/</p>
    <ul class="tree-list">
      {
        learningMapNodes.map((node) => (
          <li class="tree-node">
            <span class="node-line">
              <span class="node-label">{node.id}</span>
              <span class="node-type">[{node.type}]</span>
            </span>
            {node.summary && <span class="node-summary">{node.summary}</span>}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .topics {
    display: grid;
    gap: 1.1rem;
  }

  .tree {
    font-size: 0.875rem;
  }

  .tree-root {
    margin: 0 0 0.35rem;
    color: var(--muted);
    font-weight: 600;
  }

  .tree-list {
    display: grid;
    gap: 0.65rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tree-node {
    display: grid;
    gap: 0.15rem;
  }

  .node-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.7rem;
  }

  .node-line::before {
    content: "├── " / "";
    color: var(--faint);
    white-space: pre;
  }

  .tree-node:last-child .node-line::before {
    content: "└── " / "";
  }

  .node-label {
    color: var(--fg);
    font-weight: 600;
  }

  .node-type {
    color: var(--tk-cyan);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }

  .node-summary {
    max-width: 62ch;
    padding-left: 2.6ch;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .tree-node:not(:last-child) .node-summary {
    border-left: 1px solid var(--line);
    margin-left: 0.55ch;
    padding-left: 2.05ch;
  }
</style>
