---
import ArticleMeta from "@/components/ArticleMeta.astro";
import ArticleTOC from "@/components/ArticleTOC.astro";
import SiteShell from "@/layouts/SiteShell.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface MetaItem {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  lang?: "en" | "zh-CN";
  headings: Heading[];
  meta: MetaItem[];
  kicker?: string;
  readingMinutes?: number;
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  description,
  lang = "en",
  headings,
  meta,
  kicker,
  readingMinutes,
  backHref = import.meta.env.BASE_URL,
  backLabel = "Back"
} = Astro.props;

const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const relPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "").replace(/\/+$/, "");
const filePath = `${relPath}.md`;
---

<SiteShell title={title} description={description} lang={lang}>
  <article class="container article-grid">
    <header class="article-header">
      <p class="prompt-line" aria-hidden="true">
        <span class="prompt">$</span> <span class="cmd">cat {filePath}</span>
      </p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {kicker && <p class="kicker">{kicker}{readingMinutes ? ` · ~${readingMinutes} min read` : ""}</p>}
    </header>

    <aside class="article-rail">
      <a class="back-link" href={backHref}>&larr; {backLabel.toLowerCase()}/</a>
      <ArticleMeta items={meta} />
    </aside>

    <div class="article-content">
      {
        tocHeadings.length > 0 && (
          <details class="toc-mobile no-print">
            <summary>contents</summary>
            <ol>
              {tocHeadings.map((heading) => (
                <li class:list={{ "depth-3": heading.depth === 3 }}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ol>
          </details>
        )
      }
      <div class="article-body" data-article-body data-pagefind-body lang={lang}>
        <slot />
      </div>
      <footer class="article-footer no-print">
        <a class="back-link" href={backHref}>&larr; {backLabel.toLowerCase()}/</a>
      </footer>
    </div>

    <div class="article-toc-panel no-print">
      <ArticleTOC headings={headings} />
    </div>
  </article>
</SiteShell>

<script>
  // Code frames: title bar with language label + always-visible copy button.
  document.querySelectorAll("[data-article-body] pre").forEach((pre) => {
    const wrapper = document.createElement("div");
    wrapper.className = "code-frame";
    pre.parentNode?.insertBefore(wrapper, pre);

    const head = document.createElement("div");
    head.className = "code-head no-print";

    const lang = document.createElement("span");
    lang.className = "code-lang";
    lang.textContent = (pre as HTMLElement).dataset.language ?? "code";

    const button = document.createElement("button");
    button.type = "button";
    button.className = "code-copy";
    button.textContent = "copy";
    button.setAttribute("aria-label", "Copy code to clipboard");

    const live = document.createElement("span");
    live.className = "sr-only";
    live.setAttribute("aria-live", "polite");

    head.append(lang, button);
    wrapper.append(head, pre, live);

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pre.textContent ?? "");
        button.textContent = "copied";
        live.textContent = "Code copied to clipboard";
        setTimeout(() => {
          button.textContent = "copy";
          live.textContent = "";
        }, 1800);
      } catch {
        button.textContent = "press ctrl+c";
      }
    });
  });
</script>

<style>
  .article-grid {
    display: grid;
    grid-template-areas:
      "header"
      "rail"
      "content";
    grid-template-columns: minmax(0, 1fr);
    padding-block: clamp(2rem, 5vw, 3.25rem) 1rem;
    row-gap: 1.5rem;
  }

  .article-header {
    grid-area: header;
    max-width: 68ch;
  }

  .article-rail {
    grid-area: rail;
  }

  .article-content {
    grid-area: content;
    max-width: 68ch;
  }

  .article-toc-panel {
    display: none;
  }

  h1 {
    margin: 0.9rem 0 0;
    font-size: clamp(1.4rem, 4vw, 1.8rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.25;
    text-wrap: balance;
  }

  h1::before {
    content: "# " / "";
    color: var(--accent);
    font-weight: 600;
  }

  .lede {
    margin: 0.9rem 0 0;
    max-width: 60ch;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .kicker {
    margin: 0.9rem 0 0;
    color: var(--faint);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .back-link {
    display: inline-block;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 140ms ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .article-rail :global(.article-meta) {
    margin-top: 0.9rem;
  }

  .article-footer {
    margin-top: 3rem;
    border-top: 1px solid var(--line);
    padding-top: 1.1rem;
  }

  .toc-mobile {
    border-block: 1px solid var(--line);
    padding-block: 0.8rem;
    margin-bottom: 1.75rem;
  }

  .toc-mobile summary {
    cursor: pointer;
    color: var(--faint);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .toc-mobile ol {
    margin: 0.9rem 0 0.2rem;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    list-style: none;
  }

  .toc-mobile li {
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .toc-mobile .depth-3 {
    padding-left: 1rem;
  }

  .toc-mobile a {
    color: var(--muted);
    text-decoration: none;
  }

  .toc-mobile a:hover {
    color: var(--accent);
  }

  @media (min-width: 920px) {
    .article-grid {
      grid-template-areas:
        "rail header"
        "rail content";
      grid-template-columns: 15rem minmax(0, 1fr);
      column-gap: 2.5rem;
      row-gap: 0;
    }

    .article-header {
      padding-bottom: 2rem;
    }

    .article-rail {
      position: sticky;
      top: 5rem;
      align-self: start;
    }

    .toc-mobile {
      display: none;
    }
  }

  @media (min-width: 1240px) {
    .article-grid {
      grid-template-areas:
        "rail header toc"
        "rail content toc";
      grid-template-columns: 15rem minmax(0, 1fr) 13.5rem;
    }

    .article-toc-panel {
      display: block;
      grid-area: toc;
      padding-left: 1.25rem;
    }
  }
</style>

<style is:global>
  .code-frame {
    margin-block: 1.15rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
  }

  .code-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    padding: 0.35rem 0.75rem;
  }

  .code-lang {
    color: var(--tk-cyan);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  .code-copy {
    border: 1px solid var(--edge);
    border-radius: 3px;
    background: transparent;
    color: var(--faint);
    font-family: inherit;
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    padding: 0.14rem 0.5rem;
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease;
  }

  .code-copy:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .code-frame pre {
    margin-block: 0;
    border: 0;
    border-radius: 0;
  }
</style>
