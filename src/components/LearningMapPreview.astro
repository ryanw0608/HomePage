---
import { learningMapEdges, learningMapNodes } from "@/data/learning-map";

const nodePositions = [
  { x: 22, y: 38 },
  { x: 68, y: 58 },
  { x: 48, y: 24 },
  { x: 82, y: 30 }
];

const visualNodes = learningMapNodes.slice(0, nodePositions.length);
const hiddenNodeCount = learningMapNodes.length - visualNodes.length;
const positionedNodes = visualNodes.map((node, index) => ({
  ...node,
  position: nodePositions[index]
}));
const visibleNodeIds = new Set(positionedNodes.map((node) => node.id));
const visibleEdges = learningMapEdges.filter((edge) => visibleNodeIds.has(edge.from) && visibleNodeIds.has(edge.to));
---

<section class="learning-map-preview" aria-labelledby="learning-map-title">
  <div class="map-copy">
    <p class="eyebrow">Knowledge graph</p>
    <h2 id="learning-map-title">Learning Map</h2>
    <p class="map-description">
      A compact view of the topics, papers, and foundations that are gradually becoming a durable academic knowledge base.
    </p>
    <dl class="map-stats" aria-label="Learning map summary">
      <div>
        <dt>{learningMapNodes.length}</dt>
        <dd>nodes</dd>
      </div>
      <div>
        <dt>{learningMapEdges.length}</dt>
        <dd>connections</dd>
      </div>
    </dl>
  </div>

  <div class="map-board" aria-hidden="true">
    <svg class="map-lines" viewBox="0 0 100 80">
      {
        visibleEdges.map((edge) => {
          const from = positionedNodes.find((node) => node.id === edge.from);
          const to = positionedNodes.find((node) => node.id === edge.to);

          if (!from || !to) return null;

          return (
            <line
              x1={from.position.x}
              y1={from.position.y}
              x2={to.position.x}
              y2={to.position.y}
              vector-effect="non-scaling-stroke"
            />
          );
        })
      }
    </svg>
    {
      positionedNodes.map((node) => (
        <div
          class:list={["map-node", `node-${node.type}`]}
          style={`--x: ${node.position.x}%; --y: ${node.position.y}%;`}
        >
          <span class="node-label">{node.label}</span>
          <span class="node-type">{node.type}</span>
        </div>
      ))
    }
    {
      hiddenNodeCount > 0 && (
        <div class="more-node">
          <span>+{hiddenNodeCount} more</span>
        </div>
      )
    }
  </div>

  <ul class="node-list">
    {
      learningMapNodes.map((node) => (
        <li>
          <span>{node.label}</span>
          <small>{node.summary}</small>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .learning-map-preview {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(320px, 1.12fr);
    gap: 1.5rem;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--surface-strong) 92%, transparent), var(--surface)),
      var(--surface);
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .map-copy {
    display: grid;
    align-content: start;
    gap: 0.875rem;
  }

  .eyebrow,
  h2,
  .map-description,
  .map-stats {
    margin: 0;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(1.7rem, 3vw, 2.45rem);
    line-height: 1.05;
  }

  .map-description {
    color: var(--muted);
    line-height: 1.65;
  }

  .map-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .map-stats div {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface-strong);
    padding: 0.875rem;
  }

  .map-stats dt {
    color: var(--text);
    font-size: 1.55rem;
    font-weight: 800;
    line-height: 1;
  }

  .map-stats dd {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .map-board {
    position: relative;
    min-height: 280px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background:
      linear-gradient(color-mix(in oklab, var(--border) 42%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklab, var(--border) 42%, transparent) 1px, transparent 1px),
      var(--surface-strong);
    background-size: 32px 32px;
  }

  .map-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .map-lines line {
    stroke: color-mix(in oklab, var(--accent) 72%, var(--text));
    stroke-dasharray: 6 5;
    stroke-linecap: round;
    stroke-width: 2;
  }

  .map-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    display: grid;
    min-width: 9.5rem;
    max-width: 12rem;
    transform: translate(-50%, -50%);
    gap: 0.28rem;
    border: 1px solid color-mix(in oklab, var(--accent) 35%, var(--border));
    border-left: 4px solid var(--accent);
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--surface-strong) 94%, var(--accent));
    box-shadow: 0 14px 34px color-mix(in oklab, #000 10%, transparent);
    padding: 0.72rem 0.8rem;
  }

  .node-label {
    font-weight: 800;
    line-height: 1.15;
  }

  .node-type {
    color: var(--muted);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .node-method {
    border-left-color: var(--accent-2);
  }

  .more-node {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 800;
    padding: 0.45rem 0.65rem;
  }

  .node-list {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .node-list li {
    display: grid;
    gap: 0.35rem;
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .node-list span {
    font-weight: 750;
  }

  .node-list small {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  @media (max-width: 800px) {
    .learning-map-preview {
      grid-template-columns: 1fr;
    }

    .map-board {
      min-height: 250px;
    }
  }

  @media (max-width: 560px) {
    .node-list,
    .map-stats {
      grid-template-columns: 1fr;
    }

    .map-node {
      min-width: 8rem;
      max-width: 9.5rem;
      padding: 0.65rem;
    }
  }
</style>
