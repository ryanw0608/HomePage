---
interface Props {
  id?: string;
  items: string[];
}
const { id = "key-takeaways", items } = Astro.props;
---

<section class="takeaways" aria-labelledby={id}>
  <h2 id={id}>Key Takeaways</h2>
  <ul>
    {items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .takeaways {
    border-block: 1px solid var(--line);
    margin-block: 1.6rem;
    padding-block: 0.4rem 1.1rem;
  }

  .takeaways ul {
    margin-bottom: 0;
  }
</style>
