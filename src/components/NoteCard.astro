---
import { tags as tagDefinitions } from "@/data/taxonomy";

interface Props {
  href: string;
  title: string;
  summary: string;
  meta: string;
  tags: string[];
  headingLevel?: "h2" | "h3";
}

const { href, title, summary, meta, tags, headingLevel = "h2" } = Astro.props;
const HeadingTag = headingLevel;
const displayTags = tags.map((tag) => tagDefinitions[tag as keyof typeof tagDefinitions]?.label ?? tag);
---

<article class="note-card">
  <a class="note-card-link" href={href}>
    <p class="note-meta">{meta}</p>
    <HeadingTag>{title}</HeadingTag>
    <p class="note-summary">{summary}</p>
    {
      displayTags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {displayTags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
  </a>
</article>

<style>
  .note-card {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
  }

  .note-card-link {
    display: grid;
    gap: 0.75rem;
    height: 100%;
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
  }

  .note-card-link:hover :is(h2, h3) {
    color: var(--accent);
  }

  .note-meta,
  .note-summary,
  :is(h2, h3) {
    margin: 0;
  }

  .note-meta {
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  :is(h2, h3) {
    font-size: 1.22rem;
    line-height: 1.25;
  }

  .note-summary {
    color: var(--muted);
    line-height: 1.6;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-strong);
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1;
    padding: 0.38rem 0.55rem;
  }
</style>
