---
import { getCollection } from "astro:content";

import EntryRow from "@/components/EntryRow.astro";
import LearningMapPreview from "@/components/LearningMapPreview.astro";
import { profile } from "@/data/profile";
import { courses } from "@/data/taxonomy";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc, entryPath, publicEntries, readingTime } from "@/lib/content";

const base = import.meta.env.BASE_URL;
const allCourseNotes = publicEntries(await getCollection("course-notes")).sort(byDateDesc);
const allPaperReadings = publicEntries(await getCollection("paper-reading")).sort(byDateDesc);

const latestWriting = [
  ...allCourseNotes.map((entry) => ({
    collection: "course-notes" as const,
    entry,
    annotation: `Course note · ${courses[entry.data.course].label}`
  })),
  ...allPaperReadings.map((entry) => ({
    collection: "paper-reading" as const,
    entry,
    annotation: ["Paper reading", entry.data.paperTitle, entry.data.venue, String(entry.data.year)]
      .filter(Boolean)
      .join(" · ")
  }))
]
  .sort((a, b) => byDateDesc(a.entry, b.entry))
  .slice(0, 5);
---

<SiteShell title="Yongzhe Wang" description="Academic homepage, course notes, and paper reading notes by Yongzhe Wang.">
  <div class="container home">
    <header class="rail rise home-hero" style="--rise-order: 0;">
      <p class="rail-label">Profile</p>
      <div class="rail-body">
        <h1 class="title-serif">{profile.name}</h1>
        <p class="hero-meta">
          {profile.secondaryName} · {profile.role} · {profile.location}
        </p>
        <p class="hero-abstract">{profile.summary}</p>
        <p class="hero-note">
          Notes here are written to be revisited: course material as reusable explanations, papers as structured
          reviews with their assumptions and limitations on record.
        </p>
        <nav class="hero-links" aria-label="Profile links">
          {
            profile.links.map((link) => (
              <a href={link.href} rel="noopener noreferrer">{link.label} &nearr;</a>
            ))
          }
          <a href={`${base}about/`}>About</a>
          <a href={`${base}rss.xml`}>RSS</a>
        </nav>
      </div>
    </header>

    <section class="rail rise" aria-labelledby="focus-label" style="--rise-order: 1;">
      <p class="rail-label" id="focus-label">Now</p>
      <div class="rail-body">
        <dl class="focus-list">
          {
            profile.currentFocus.map((focus) => (
              <div class="focus-item">
                <dt>{focus.label}</dt>
                <dd>{focus.description}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="rail rise" aria-labelledby="writing-label" style="--rise-order: 2;">
      <p class="rail-label" id="writing-label">Writing</p>
      <div class="rail-body">
        {
          latestWriting.map(({ collection, entry, annotation }) => (
            <EntryRow
              href={entryPath(collection, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              datestamp={entry.data.date.toISOString().slice(0, 10)}
              annotation={annotation}
              tags={entry.data.tags}
              minutes={readingTime(entry.body ?? "")}
              headingLevel="h2"
            />
          ))
        }
        <nav class="writing-links" aria-label="Writing indexes">
          <a href={`${base}course-notes/`}>All course notes &rarr;</a>
          <a href={`${base}paper-reading/`}>All paper reading &rarr;</a>
        </nav>
      </div>
    </section>

    <LearningMapPreview />
  </div>
</SiteShell>

<style>
  .home {
    display: grid;
    gap: clamp(2.75rem, 6vw, 4.5rem);
    padding-block: clamp(2.5rem, 6vw, 4.5rem) 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 3.7rem);
    line-height: 1.05;
  }

  .hero-meta {
    margin: 1rem 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
  }

  .hero-abstract {
    margin: 1.5rem 0 0;
    max-width: 34em;
    font-family: var(--font-serif);
    font-size: 1.22rem;
    line-height: 1.62;
  }

  .hero-note {
    margin: 0.9rem 0 0;
    max-width: 56ch;
    color: var(--muted);
    line-height: 1.65;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin-top: 1.6rem;
  }

  .hero-links a,
  .writing-links a {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    padding-bottom: 0.1rem;
    transition: border-color 140ms ease;
  }

  .hero-links a:hover,
  .writing-links a:hover {
    border-bottom-color: var(--accent);
  }

  .focus-list {
    display: grid;
    margin: 0;
  }

  .focus-item {
    display: grid;
    gap: 0.35rem;
    border-top: 1px solid var(--line);
    padding-block: 1rem;
  }

  .focus-item:first-child {
    border-top: 0;
    padding-top: 0.2rem;
  }

  .focus-item dt {
    font-family: var(--font-serif);
    font-size: 1.12rem;
    font-weight: 540;
    letter-spacing: -0.01em;
  }

  .focus-item dd {
    margin: 0;
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.62;
  }

  .writing-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    border-top: 1px solid var(--line);
    padding-top: 1.2rem;
  }

  @media (min-width: 640px) {
    .focus-item {
      grid-template-columns: 14rem minmax(0, 1fr);
      column-gap: 1.5rem;
    }
  }
</style>
