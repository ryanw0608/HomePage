---
import ArticleMeta from "@/components/ArticleMeta.astro";
import ArticleTOC from "@/components/ArticleTOC.astro";
import SiteShell from "@/layouts/SiteShell.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  description: string;
  lang?: "en" | "zh-CN";
  headings: Heading[];
  meta: MetaItem[];
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  description,
  lang = "en",
  headings,
  meta,
  backHref = import.meta.env.BASE_URL,
  backLabel = "Back"
} = Astro.props;
---

<SiteShell title={title} description={description} lang={lang}>
  <article class="article-page container">
    <header class="article-header">
      <a class="back-link" href={backHref}>{backLabel}</a>
      <h1>{title}</h1>
      <p>{description}</p>
    </header>

    <div class="article-grid">
      <ArticleMeta items={meta} />
      <div class="article-body">
        <slot />
      </div>
      <ArticleTOC headings={headings} />
    </div>
  </article>
</SiteShell>

<style>
  .article-page {
    padding-block: 3rem 1rem;
  }

  .article-header {
    max-width: 760px;
    margin-inline: auto;
    padding-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.25rem;
    color: var(--muted);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text);
  }

  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    line-height: 1.05;
  }

  .article-header p {
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 1rem 0 0;
  }

  .article-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 220px;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 980px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
