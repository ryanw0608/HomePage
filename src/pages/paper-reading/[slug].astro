---
import { getCollection, render } from "astro:content";

import { mdxComponents } from "@/components/mdx";
import Verdict from "@/components/mdx/Verdict.astro";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { entrySlug, publicEntries, readingTime } from "@/lib/content";
import { htmlLang } from "@/lib/site";

export async function getStaticPaths() {
  const papers = publicEntries(await getCollection("paper-reading"));

  return papers.map((paper) => ({
    params: { slug: entrySlug(paper) },
    props: { paper }
  }));
}

const { paper } = Astro.props;
const { Content, headings } = await render(paper);
const lang = htmlLang(paper.data.language, paper.data.primaryLanguage);
const kicker = ["Paper reading", paper.data.venue, String(paper.data.year)].filter(Boolean).join(" · ");
const minutes = readingTime(paper.body ?? "");

// The verdict strip renders automatically from frontmatter — authors never
// duplicate rating/recommendation/reproducible inside the MDX body.
const hasVerdict = Boolean(paper.data.rating || paper.data.recommendation || paper.data.reproducible);
---

<ArticleLayout
  title={paper.data.title}
  description={paper.data.description}
  lang={lang}
  headings={headings}
  kicker={kicker}
  readingMinutes={minutes}
  meta={[
    { label: "Paper", value: paper.data.paperTitle },
    { label: "Authors", value: paper.data.authors.join(", ") },
    { label: "Reviewed", value: paper.data.date.toISOString().slice(0, 10) },
    { label: "Status", value: paper.data.status },
    ...(paper.data.arxivId ? [{ label: "arXiv", value: paper.data.arxivId, href: `https://arxiv.org/abs/${paper.data.arxivId}` }] : []),
    ...(paper.data.paperUrl ? [{ label: "Source", value: "Open paper", href: paper.data.paperUrl }] : []),
    ...(paper.data.codeUrl ? [{ label: "Code", value: "Repository", href: paper.data.codeUrl }] : [])
  ]}
  backHref={`${import.meta.env.BASE_URL}paper-reading/`}
  backLabel="Paper reading"
>
  {
    hasVerdict && (
      <Verdict
        rating={paper.data.rating}
        recommendation={paper.data.recommendation}
        reproducible={paper.data.reproducible}
        effort={`~${minutes} min read`}
      />
    )
  }
  <Content components={mdxComponents} />
</ArticleLayout>
