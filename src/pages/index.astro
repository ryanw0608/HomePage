---
import { getCollection } from "astro:content";

import BootSequence from "@/components/BootSequence.astro";
import EntryRow from "@/components/EntryRow.astro";
import TokenStream from "@/components/TokenStream.astro";
import LearningMapPreview from "@/components/LearningMapPreview.astro";
import { profile } from "@/data/profile";
import { courses } from "@/data/taxonomy";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc, entryPath, publicEntries, readingTime } from "@/lib/content";

const base = import.meta.env.BASE_URL;
const allCourseNotes = publicEntries(await getCollection("course-notes")).sort(byDateDesc);
const allPaperReadings = publicEntries(await getCollection("paper-reading")).sort(byDateDesc);
const entryCount = allCourseNotes.length + allPaperReadings.length;

const latestWriting = [
  ...allCourseNotes.map((entry) => ({
    collection: "course-notes" as const,
    entry,
    annotation: `course note · ${courses[entry.data.course].label}`
  })),
  ...allPaperReadings.map((entry) => ({
    collection: "paper-reading" as const,
    entry,
    annotation: ["paper reading", entry.data.paperTitle, entry.data.venue, String(entry.data.year)]
      .filter(Boolean)
      .join(" · ")
  }))
]
  .sort((a, b) => byDateDesc(a.entry, b.entry))
  .slice(0, 5);
---

<SiteShell title="Yongzhe Wang" description="Academic homepage, course notes, and paper reading notes by Yongzhe Wang.">
  <BootSequence entryCount={entryCount} interestCount={profile.currentFocus.length} />

  <div class="container home">
    <header class="home-hero rise" style="--rise-order: 0;">
      <p class="prompt-line" aria-hidden="true"><span class="prompt">$</span> <span class="cmd">whoami</span></p>
      <h1 class="caret">{profile.name}</h1>
      <p class="hero-meta">
        {profile.secondaryName} · MSc computer science · University of Sydney · {profile.location}
      </p>
      <p class="hero-affil">
        <a href={profile.lab.href} rel="noopener noreferrer">{profile.lab.shortName} &nearr;</a>
        {" · advised by "}
        <a href={profile.advisors[0].href} rel="noopener noreferrer">{profile.advisors[0].name}</a>
        {" & "}
        <a href={profile.advisors[1].href} rel="noopener noreferrer">{profile.advisors[1].name}</a>
      </p>
      <p class="hero-abstract">{profile.summary}</p>
      <nav class="hero-links" aria-label="Profile links">
        {
          profile.links.map((link) => (
            <a href={link.href} rel="noopener noreferrer">{link.label.toLowerCase()} &nearr;</a>
          ))
        }
        <a href={`${base}about/`}>about</a>
        <a href={`${base}rss.xml`}>rss</a>
      </nav>
    </header>

    <TokenStream />

    <section class="rise" aria-labelledby="focus-title" style="--rise-order: 2;">
      <h2 class="sr-only" id="focus-title">Research focus</h2>
      <p class="prompt-line" aria-hidden="true"><span class="prompt">$</span> <span class="cmd">cat focus.md</span></p>
      <ol class="focus-list">
        {
          profile.currentFocus.map((focus) => (
            <li class="focus-item">
              <span class="focus-label">{focus.label}</span>
              <span class="focus-desc">{focus.description}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="rise" aria-labelledby="writing-title" style="--rise-order: 3;">
      <h2 class="sr-only" id="writing-title">Latest writing</h2>
      <p class="prompt-line" aria-hidden="true">
        <span class="prompt">$</span> <span class="cmd">ls writing/ --sort=date</span>
      </p>
      <div class="writing-list">
        {
          latestWriting.map(({ collection, entry, annotation }) => (
            <EntryRow
              href={entryPath(collection, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              datestamp={entry.data.date.toISOString().slice(0, 10)}
              annotation={annotation}
              tags={entry.data.tags}
              minutes={readingTime(entry.body ?? "")}
              headingLevel="h3"
            />
          ))
        }
      </div>
      <nav class="writing-links" aria-label="Writing indexes">
        <a href={`${base}course-notes/`}>cd course-notes/ &rarr;</a>
        <a href={`${base}paper-reading/`}>cd paper-reading/ &rarr;</a>
      </nav>
    </section>

    <LearningMapPreview />
  </div>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: profile.name,
      alternateName: profile.secondaryName,
      affiliation: {
        "@type": "Organization",
        name: profile.lab.name,
        url: profile.lab.href
      },
      alumniOf: profile.education.map((item) => ({ "@type": "CollegeOrUniversity", name: item.school })),
      url: "https://ryanw0608.github.io/HomePage/",
      sameAs: profile.links.map((link) => link.href)
    })}
  />
</SiteShell>

<style>
  .home {
    display: grid;
    gap: clamp(3rem, 7vw, 4.75rem);
    padding-block: clamp(2.5rem, 7vw, 5rem) 1rem;
  }

  .home-hero {
    display: grid;
    gap: 0;
  }

  h1 {
    margin: 0.9rem 0 0;
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .hero-meta {
    margin: 1rem 0 0;
    color: var(--faint);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .hero-affil {
    margin: 0.55rem 0 0;
    color: var(--faint);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .hero-affil a {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
    text-decoration-color: color-mix(in oklab, var(--accent) 40%, transparent);
    transition: color 140ms ease, text-decoration-color 140ms ease;
  }

  .hero-affil a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .affil-sep {
    color: var(--faint);
  }

  .hero-abstract {
    margin: 1.4rem 0 0;
    max-width: 62ch;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    margin-top: 1.5rem;
  }

  .hero-links a,
  .writing-links a {
    color: var(--accent);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    padding-bottom: 0.12rem;
    transition: border-color 140ms ease;
  }

  .hero-links a:hover,
  .writing-links a:hover {
    border-bottom-color: var(--accent);
  }

  section {
    display: grid;
    gap: 1.1rem;
  }

  .focus-list {
    display: grid;
    gap: 0;
    list-style: none;
    counter-reset: focus;
    margin: 0;
    padding: 0;
  }

  .focus-item {
    display: grid;
    gap: 0.3rem;
    border-top: 1px solid var(--line);
    padding-block: 1.05rem;
    counter-increment: focus;
  }

  .focus-item:first-child {
    border-top: 0;
    padding-top: 0.15rem;
  }

  .focus-label {
    color: var(--fg);
    font-size: 1rem;
    font-weight: 650;
  }

  .focus-label::before {
    content: counter(focus, decimal-leading-zero) "  " / "";
    color: var(--tk-orange);
    font-size: 0.8rem;
    font-weight: 500;
    white-space: pre;
  }

  .focus-desc {
    max-width: 64ch;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .writing-list {
    display: grid;
  }

  .writing-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    border-top: 1px solid var(--line);
    padding-top: 1.1rem;
  }

  @media (min-width: 640px) {
    .focus-item {
      grid-template-columns: 19rem minmax(0, 1fr);
      column-gap: 1.5rem;
      align-items: start;
    }

    .focus-desc {
      padding-top: 0.1rem;
    }
  }
</style>
