---
/*
 * ⌘K command palette. Pure enhancement: every navigation action here also
 * exists as a real link in the visible chrome, so nothing depends on it.
 * Native <dialog> gives the focus trap, Esc handling, and inert background.
 * Pagefind loads lazily on first use, from the built site under BASE_URL.
 */
const base = import.meta.env.BASE_URL;
const href = (pathname = "") => `${base}${pathname.replace(/^\/+/, "")}`;

const navActions = [
  { label: "cd ~/", hint: "home", href: href() },
  { label: "cd course-notes/", hint: "index", href: href("course-notes/") },
  { label: "cd paper-reading/", hint: "index", href: href("paper-reading/") },
  { label: "cd about/", hint: "page", href: href("about/") },
  { label: "open rss.xml", hint: "feed", href: href("rss.xml") }
];
---

<dialog class="palette no-print" data-palette aria-label="Command palette">
  <div class="palette-head">
    <span class="palette-prompt" aria-hidden="true">&rsaquo;</span>
    <input
      data-palette-input
      type="text"
      placeholder="type a command or search notes…"
      role="combobox"
      aria-expanded="true"
      aria-autocomplete="list"
      aria-controls="palette-list"
      autocomplete="off"
      spellcheck="false"
    />
    <kbd>esc</kbd>
  </div>
  <ul id="palette-list" role="listbox" aria-label="Commands" data-palette-list>
    {
      navActions.map((action, index) => (
        <li
          id={`pal-nav-${index}`}
          role="option"
          aria-selected="false"
          data-palette-option
          data-kind="nav"
          data-href={action.href}
          data-text={action.label}
        >
          <span class="opt-label">{action.label}</span>
          <span class="opt-hint">{action.hint}</span>
        </li>
      ))
    }
    <li
      id="pal-theme"
      role="option"
      aria-selected="false"
      data-palette-option
      data-kind="theme"
      data-text="theme toggle dark light"
    >
      <span class="opt-label">theme --toggle</span>
      <span class="opt-hint">dark / light</span>
    </li>
    <li
      id="pal-boot"
      role="option"
      aria-selected="false"
      data-palette-option
      data-kind="boot"
      data-text="boot replay intro"
    >
      <span class="opt-label">boot --replay</span>
      <span class="opt-hint">intro</span>
    </li>
    <li
      id="pal-copy"
      role="option"
      aria-selected="false"
      data-palette-option
      data-kind="copy"
      data-text="copy page url link"
    >
      <span class="opt-label">copy $PWD</span>
      <span class="opt-hint">page url</span>
    </li>
  </ul>
  <p class="palette-status" data-palette-status aria-live="polite"></p>
</dialog>

<script>
  const dialog = document.querySelector<HTMLDialogElement>("[data-palette]");
  const input = dialog?.querySelector<HTMLInputElement>("[data-palette-input]");
  const list = dialog?.querySelector<HTMLElement>("[data-palette-list]");
  const status = dialog?.querySelector<HTMLElement>("[data-palette-status]");

  if (dialog && input && list && status) {
    const BASE = import.meta.env.BASE_URL;
    let pagefind: { search: (q: string) => Promise<{ results: PagefindResult[] }> } | null | undefined;
    let searchToken = 0;
    let active = -1;

    interface PagefindResult {
      id: string;
      data: () => Promise<{ url: string; excerpt: string; meta: { title?: string } }>;
    }

    const options = () =>
      Array.from(list.querySelectorAll<HTMLElement>("[data-palette-option]:not([hidden])"));

    const setActive = (index: number) => {
      const visible = options();
      active = visible.length === 0 ? -1 : Math.max(0, Math.min(index, visible.length - 1));
      list.querySelectorAll("[data-palette-option]").forEach((option) => {
        option.setAttribute("aria-selected", "false");
        option.classList.remove("is-active");
      });
      const current = visible[active];
      if (current) {
        current.setAttribute("aria-selected", "true");
        current.classList.add("is-active");
        current.scrollIntoView({ block: "nearest" });
        input.setAttribute("aria-activedescendant", current.id);
      } else {
        input.removeAttribute("aria-activedescendant");
      }
    };

    const filterStatic = (query: string) => {
      const q = query.trim().toLowerCase();
      list.querySelectorAll<HTMLElement>("[data-palette-option]:not([data-kind='result'])").forEach((option) => {
        const text = option.dataset.text ?? "";
        option.hidden = q.length > 0 && !text.toLowerCase().includes(q);
      });
    };

    const clearResults = () => {
      list.querySelectorAll("[data-kind='result']").forEach((node) => node.remove());
    };

    const ensurePagefind = async () => {
      if (pagefind !== undefined) return pagefind;
      try {
        // Built by `pagefind --site dist` after astro build; absent in dev.
        const module = await import(/* @vite-ignore */ `${BASE}pagefind/pagefind.js`);
        await module.init?.();
        pagefind = module;
      } catch {
        pagefind = null;
      }
      return pagefind;
    };

    const runSearch = async (query: string) => {
      const token = ++searchToken;
      const engine = await ensurePagefind();

      if (token !== searchToken) return;

      if (!engine) {
        status.textContent = "full-text search is available on the production build";
        return;
      }

      const { results } = await engine.search(query);
      if (token !== searchToken) return;

      clearResults();
      const top = await Promise.all(results.slice(0, 8).map((result) => result.data()));
      if (token !== searchToken) return;

      top.forEach((data, index) => {
        const li = document.createElement("li");
        li.id = `pal-result-${index}`;
        li.setAttribute("role", "option");
        li.setAttribute("aria-selected", "false");
        li.dataset.paletteOption = "";
        li.dataset.kind = "result";
        li.dataset.href = data.url;

        const label = document.createElement("span");
        label.className = "opt-label";
        label.textContent = data.meta.title ?? data.url;

        const excerpt = document.createElement("span");
        excerpt.className = "opt-excerpt";
        excerpt.innerHTML = data.excerpt;

        li.append(label, excerpt);
        list.append(li);
      });

      status.textContent = top.length === 0 ? `no matches for "${query}"` : "";
      setActive(0);
    };

    let searchTimer = 0;
    const onInput = () => {
      const query = input.value;
      filterStatic(query);
      clearTimeout(searchTimer);

      if (query.trim().length < 2) {
        clearResults();
        status.textContent = "";
        setActive(0);
        return;
      }

      searchTimer = window.setTimeout(() => runSearch(query.trim()), 160);
      setActive(0);
    };

    const activate = (option: HTMLElement) => {
      const kind = option.dataset.kind;

      if (kind === "nav" || kind === "result") {
        dialog.close();
        window.location.href = option.dataset.href ?? BASE;
      } else if (kind === "theme") {
        const root = document.documentElement;
        const nextTheme = root.dataset.theme === "light" ? "dark" : "light";
        root.dataset.theme = nextTheme;
        try {
          window.localStorage?.setItem("theme", nextTheme);
        } catch {
          // Storage may be unavailable; the in-page toggle still applied.
        }
        status.textContent = `theme set to ${nextTheme}`;
      } else if (kind === "boot") {
        try {
          window.sessionStorage?.removeItem("yw:boot");
        } catch {
          // Ignore storage failures; navigation still works.
        }
        dialog.close();
        window.location.href = BASE;
      } else if (kind === "copy") {
        navigator.clipboard
          ?.writeText(window.location.href)
          .then(() => {
            status.textContent = "page url copied";
          })
          .catch(() => {
            status.textContent = window.location.href;
          });
      }
    };

    const open = () => {
      if (dialog.open) return;
      dialog.showModal();
      input.value = "";
      clearResults();
      filterStatic("");
      status.textContent = "";
      setActive(0);
    };

    input.addEventListener("input", onInput);

    input.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        setActive(active + 1);
      } else if (event.key === "ArrowUp") {
        event.preventDefault();
        setActive(active - 1);
      } else if (event.key === "Enter") {
        event.preventDefault();
        const current = options()[active];
        if (current) activate(current);
      }
    });

    list.addEventListener("click", (event) => {
      const option = (event.target as HTMLElement).closest<HTMLElement>("[data-palette-option]");
      if (option) activate(option);
    });

    window.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        if (dialog.open) {
          dialog.close();
        } else {
          open();
        }
      }
    });

    document.querySelectorAll("[data-palette-open]").forEach((trigger) => {
      (trigger as HTMLElement).hidden = false;
      trigger.addEventListener("click", open);
    });
  }
</script>

<style>
  .palette {
    width: min(36rem, calc(100vw - 2.5rem));
    margin: 15vh auto auto;
    border: 1px solid var(--edge);
    border-radius: 8px;
    background: var(--bg);
    color: var(--fg);
    padding: 0;
    overflow: hidden;
  }

  .palette::backdrop {
    background: color-mix(in oklab, #000 55%, transparent);
    backdrop-filter: blur(2px);
  }

  .palette-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
    padding: 0.75rem 0.9rem;
  }

  .palette-prompt {
    color: var(--accent);
    font-weight: 700;
  }

  input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--fg);
    font-family: inherit;
    font-size: 0.9rem;
  }

  input:focus {
    outline: none;
  }

  input::placeholder {
    color: var(--faint);
  }

  kbd {
    border: 1px solid var(--edge);
    border-radius: 3px;
    color: var(--faint);
    font-family: inherit;
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    padding: 0.12rem 0.4rem;
  }

  .palette-status {
    margin: 0;
    min-height: 1.6rem;
    border-top: 1px solid var(--line);
    color: var(--faint);
    font-size: 0.72rem;
    padding: 0.35rem 0.9rem;
  }
</style>

{/* Result rows are created at runtime and carry no Astro scope attribute,
    so their styles must be global, namespaced under [data-palette]. */}
<style is:global>
  [data-palette] #palette-list {
    max-height: 21rem;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    padding: 0.45rem;
  }

  [data-palette] [data-palette-option] {
    display: grid;
    gap: 0.15rem;
    border-radius: 4px;
    padding: 0.5rem 0.65rem;
    cursor: pointer;
  }

  [data-palette] [data-palette-option].is-active {
    background: color-mix(in oklab, var(--accent) 12%, transparent);
  }

  [data-palette] .opt-label {
    color: var(--fg);
    font-size: 0.85rem;
    font-weight: 550;
  }

  [data-palette] [data-palette-option].is-active .opt-label {
    color: var(--accent);
  }

  [data-palette] .opt-hint {
    color: var(--faint);
    font-size: 0.72rem;
  }

  [data-palette] .opt-excerpt {
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  [data-palette] .opt-excerpt mark {
    background: transparent;
    color: var(--accent);
    font-weight: 650;
  }
</style>
