---
import SiteShell from "@/layouts/SiteShell.astro";

const base = import.meta.env.BASE_URL;
const href = (pathname = "") => `${base}${pathname.replace(/^\/+/, "")}`;
---

<SiteShell title="Page not found" description="The requested page could not be found.">
  <section class="container not-found" aria-labelledby="not-found-title">
    <p class="prompt-line" aria-hidden="true">
      <span class="prompt">$</span> <span class="cmd">cat requested-page</span>
    </p>
    <h1 id="not-found-title">404: no such file or directory</h1>
    <p class="hint">The requested page could not be found. It may have moved, or the address may be mistyped.</p>
    <nav aria-label="Helpful links">
      <a href={href()}>cd ~/</a>
      <a href={href("course-notes/")}>cd course-notes/</a>
      <a href={href("paper-reading/")}>cd paper-reading/</a>
    </nav>
  </section>
</SiteShell>

<style>
  .not-found {
    display: grid;
    min-height: 52vh;
    align-content: center;
    justify-items: start;
    gap: 0.9rem;
    padding-block: 3rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.5rem, 4.5vw, 2.1rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--tk-red);
  }

  .hint {
    margin: 0;
    max-width: 52ch;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
    margin-top: 0.8rem;
  }

  nav a {
    color: var(--accent);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    padding-bottom: 0.12rem;
    transition: border-color 140ms ease;
  }

  nav a:hover {
    border-bottom-color: var(--accent);
  }
</style>
