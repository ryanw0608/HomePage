---
import { tags as tagDefinitions } from "@/data/taxonomy";

interface Props {
  href: string;
  title: string;
  summary: string;
  datestamp: string;
  annotation?: string;
  tags?: string[];
  minutes?: number;
  headingLevel?: "h2" | "h3";
}

const { href, title, summary, datestamp, annotation, tags = [], minutes, headingLevel = "h2" } = Astro.props;
const HeadingTag = headingLevel;
const displayTags = tags.map((tag) => tagDefinitions[tag as keyof typeof tagDefinitions]?.label ?? tag);
const dataline = [
  ...displayTags,
  ...(minutes ? [`~${minutes} min`] : [])
];
---

<article class="entry-row">
  <p class="entry-date">{datestamp}</p>
  <div class="entry-main">
    <HeadingTag class="entry-title">
      <a href={href}>{title}</a>
    </HeadingTag>
    {annotation && <p class="entry-annotation">{annotation}</p>}
    <p class="entry-summary">{summary}</p>
    {
      dataline.length > 0 && (
        <p class="entry-data" aria-label="Tags and reading time">
          {dataline.join(" · ")}
        </p>
      )
    }
  </div>
</article>

<style>
  .entry-row {
    display: grid;
    gap: 0.3rem;
    border-top: 1px solid var(--line);
    padding-block: 1.3rem;
  }

  .entry-row:first-of-type {
    border-top: 0;
    padding-top: 0.2rem;
  }

  .entry-date {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .entry-main {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .entry-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.22rem;
    font-weight: 540;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .entry-title a {
    color: var(--ink);
    text-decoration: none;
    transition: color 140ms ease;
  }

  .entry-title a:hover {
    color: var(--accent);
  }

  .entry-annotation {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .entry-summary {
    margin: 0;
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.62;
  }

  .entry-data {
    margin: 0.15rem 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  @media (min-width: 640px) {
    .entry-row {
      grid-template-columns: 7rem minmax(0, 1fr);
      column-gap: 1.5rem;
    }

    .entry-date {
      padding-top: 0.3rem;
    }
  }
</style>
