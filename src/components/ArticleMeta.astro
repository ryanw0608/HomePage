---
interface MetaItem {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  items: MetaItem[];
}

const { items } = Astro.props;
const isDataValue = (value: string) => /^\d{4}-\d{2}-\d{2}$/.test(value) || /^\d+$/.test(value);
---

{/* The article's own frontmatter, rendered as the YAML block it really is. */}
<aside class="article-meta" aria-label="Article metadata">
  <p class="fence" aria-hidden="true">---</p>
  <dl>
    {
      items.map((item) => (
        <div class="meta-row">
          <dt>{item.label.toLowerCase()}:</dt>
          <dd class:list={{ "is-data": isDataValue(item.value) }}>
            {
              item.href ? (
                <a href={item.href} rel="noopener noreferrer" target="_blank">{item.value} &nearr;</a>
              ) : (
                item.value
              )
            }
          </dd>
        </div>
      ))
    }
  </dl>
  <p class="fence" aria-hidden="true">---</p>
</aside>

<style>
  .article-meta {
    border: 1px solid var(--line);
    border-radius: 6px;
    background: color-mix(in oklab, var(--surface) 70%, var(--bg));
    padding: 0.8rem 1rem;
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .fence {
    margin: 0;
    color: var(--faint);
    user-select: none;
  }

  dl {
    display: grid;
    gap: 0.3rem;
    margin: 0.35rem 0;
  }

  .meta-row {
    display: grid;
    grid-template-columns: 5.4rem minmax(0, 1fr);
    column-gap: 0.6rem;
  }

  dt {
    color: var(--tk-cyan);
  }

  dd {
    margin: 0;
    color: var(--tk-green);
    overflow-wrap: break-word;
  }

  dd.is-data {
    color: var(--tk-orange);
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }
</style>
