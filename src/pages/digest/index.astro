---
import { getCollection } from "astro:content";

import EntryRow from "@/components/EntryRow.astro";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc } from "@/lib/content";

const base = import.meta.env.BASE_URL;
const digests = (await getCollection("digest")).sort(byDateDesc);
---

<SiteShell title="Digest" description="Weekly agent-written digests of the notes on this site.">
  <section class="container index-page">
    <header class="index-header">
      <p class="prompt-line" aria-hidden="true">
        <span class="prompt">$</span> <span class="cmd">ls digest/ --weekly</span>
      </p>
      <h1>Digest</h1>
      <p class="page-lede">
        Weekly summaries of this notebook, written automatically by the site agent from the committed notes and
        merged after review. Derived content — the notes themselves are the source of truth.
      </p>
      <p class="page-count" aria-label="Digest count">
        {digests.length} {digests.length === 1 ? "digest" : "digests"}
      </p>
    </header>

    {
      digests.length === 0 ? (
        <p class="empty-state">no digests yet — the agent writes one every sunday once its API key is configured.</p>
      ) : (
        <div class="digest-list">
          {digests.map((digest) => (
            <EntryRow
              href={`${base}digest/${digest.id}/`}
              title={digest.data.title}
              summary={digest.data.summary}
              datestamp={digest.data.date.toISOString().slice(0, 10)}
              annotation={digest.data.model ? `generated by ${digest.data.model}` : "agent-generated"}
            />
          ))}
        </div>
      )
    }
  </section>
</SiteShell>

<style>
  .index-page {
    display: grid;
    gap: 2.4rem;
    padding-block: clamp(2.5rem, 6vw, 4rem) 1rem;
  }

  .index-header {
    display: grid;
    gap: 0;
  }

  h1 {
    margin: 0.9rem 0 0;
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  h1::before {
    content: "# " / "";
    color: var(--accent);
    font-weight: 600;
  }

  .page-lede {
    margin: 0.9rem 0 0;
    max-width: 62ch;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .page-count {
    margin: 0.9rem 0 0;
    color: var(--faint);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }

  .empty-state {
    margin: 0;
    color: var(--faint);
    font-size: 0.9rem;
  }
</style>
