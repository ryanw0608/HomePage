---
import { getCollection } from "astro:content";

import EntryRow from "@/components/EntryRow.astro";
import { courses } from "@/data/taxonomy";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc, entryPath, publicEntries, readingTime } from "@/lib/content";

const notes = publicEntries(await getCollection("course-notes")).sort(byDateDesc);

const courseIds = [...new Set(notes.map((note) => note.data.course))];
const groups = courseIds.map((courseId) => ({
  course: courses[courseId],
  notes: notes.filter((note) => note.data.course === courseId)
}));
---

<SiteShell title="Course Notes" description="Course learning notes by Yongzhe Wang.">
  <section class="container index-page">
    <header class="rail">
      <p class="rail-label">Index</p>
      <div class="rail-body">
        <h1 class="title-serif">Course Notes</h1>
        <p class="page-lede">
          Learning notes written as reusable explanations rather than one-off summaries, grouped by course.
        </p>
        <p class="page-count" aria-label="Note count">{notes.length} {notes.length === 1 ? "note" : "notes"}</p>
      </div>
    </header>

    {
      groups.map((group) => (
        <div class="rail entry-group">
          <p class="rail-label">{group.course.label}</p>
          <div class="rail-body">
            {group.notes.map((note) => (
              <EntryRow
                href={entryPath("course-notes", note)}
                title={note.data.title}
                summary={note.data.summary}
                datestamp={note.data.date.toISOString().slice(0, 10)}
                annotation={note.data.term}
                tags={note.data.tags}
                minutes={readingTime(note.body ?? "")}
              />
            ))}
          </div>
        </div>
      ))
    }
  </section>
</SiteShell>

<style>
  .index-page {
    display: grid;
    gap: 2.5rem;
    padding-block: clamp(2rem, 5vw, 3.5rem) 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    line-height: 1.1;
  }

  .page-lede {
    margin: 0.9rem 0 0;
    max-width: 55ch;
    color: var(--muted);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.08rem;
    line-height: 1.6;
  }

  .page-count {
    margin: 1.1rem 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }
</style>
