---
import { getCollection } from "astro:content";

import EntryRow from "@/components/EntryRow.astro";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc, entryPath, publicEntries, readingTime } from "@/lib/content";

const papers = publicEntries(await getCollection("paper-reading")).sort(byDateDesc);

const reviewYears = [...new Set(papers.map((paper) => paper.data.date.getFullYear()))];
const groups = reviewYears.map((year) => ({
  year,
  papers: papers.filter((paper) => paper.data.date.getFullYear() === year)
}));
---

<SiteShell title="Paper Reading" description="Structured paper reading notes by Yongzhe Wang.">
  <section class="container index-page">
    <header class="index-header">
      <p class="prompt-line" aria-hidden="true">
        <span class="prompt">$</span> <span class="cmd">ls paper-reading/ --group=year</span>
      </p>
      <h1>Paper Reading</h1>
      <p class="page-lede">
        Reading notes, not publications: problem setting, core idea, strengths, limitations, and open questions
        for each paper.
      </p>
      <p class="page-count" aria-label="Reading count">
        {papers.length} {papers.length === 1 ? "reading" : "readings"}
      </p>
    </header>

    {
      groups.map((group) => (
        <section class="entry-group" aria-label={String(group.year)}>
          <p class="group-label" aria-hidden="true">{group.year}/</p>
          <div class="group-body">
            {group.papers.map((paper) => (
              <EntryRow
                href={entryPath("paper-reading", paper)}
                title={paper.data.title}
                summary={paper.data.summary}
                datestamp={paper.data.date.toISOString().slice(0, 10)}
                annotation={[paper.data.paperTitle, paper.data.venue, String(paper.data.year)]
                  .filter(Boolean)
                  .join(" · ")}
                tags={paper.data.tags}
                minutes={readingTime(paper.body ?? "")}
                lang={paper.data.language}
                status={paper.data.status}
                rating={paper.data.rating}
              />
            ))}
          </div>
        </section>
      ))
    }
  </section>
</SiteShell>

<style>
  .index-page {
    display: grid;
    gap: 2.4rem;
    padding-block: clamp(2.5rem, 6vw, 4rem) 1rem;
  }

  .index-header {
    display: grid;
    gap: 0;
  }

  h1 {
    margin: 0.9rem 0 0;
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  h1::before {
    content: "# " / "";
    color: var(--accent);
    font-weight: 600;
  }

  .page-lede {
    margin: 0.9rem 0 0;
    max-width: 62ch;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .page-count {
    margin: 0.9rem 0 0;
    color: var(--faint);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }

  .entry-group {
    display: grid;
    gap: 0.9rem;
  }

  .group-label {
    margin: 0;
    color: var(--tk-blue);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.02em;
  }
</style>
