---
interface Props {
  type?: "note" | "insight" | "warning" | "question" | "exam" | "definition";
  title?: string;
}
const { type = "note", title } = Astro.props;
const defaultLabels: Record<string, string> = {
  exam: "exam-trap",
  definition: "def"
};
const label = title ?? defaultLabels[type] ?? type;
---

<aside class={`callout callout-${type}`}>
  <p class="callout-label">{`// ${label.toLowerCase()}`}</p>
  <slot />
</aside>

<style>
  .callout {
    --callout-color: var(--tk-cyan);
    border-left: 2px solid var(--callout-color);
    background: color-mix(in oklab, var(--callout-color) 6%, transparent);
    margin-block: 1.4rem;
    padding: 0.85rem 1.15rem;
  }

  .callout-insight {
    --callout-color: var(--tk-green);
  }

  .callout-warning {
    --callout-color: var(--tk-yellow);
  }

  .callout-question {
    --callout-color: var(--tk-magenta);
  }

  .callout-exam {
    --callout-color: var(--tk-orange);
  }

  .callout-definition {
    --callout-color: var(--tk-blue);
  }

  .callout-label {
    margin: 0 0 0.35rem;
    color: var(--callout-color);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .callout :global(p) {
    margin-block: 0.5rem;
    font-size: 0.92rem;
  }

  .callout :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
