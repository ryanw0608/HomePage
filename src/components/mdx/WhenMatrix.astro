---
interface Props {
  helps?: string[];
  hurts?: string[];
  helpsLabel?: string;
  hurtsLabel?: string;
}
const { helps = [], hurts = [], helpsLabel = "helps when", hurtsLabel = "hurts when" } = Astro.props;
---

<div class="when-matrix">
  <section aria-label={helpsLabel}>
    <p class="matrix-label label-helps">{helpsLabel}</p>
    <ul>
      {
        helps.map((item) => (
          <li>
            <span class="mark mark-helps" aria-hidden="true">&check;</span>
            {item}
          </li>
        ))
      }
    </ul>
  </section>
  <section aria-label={hurtsLabel}>
    <p class="matrix-label label-hurts">{hurtsLabel}</p>
    <ul>
      {
        hurts.map((item) => (
          <li>
            <span class="mark mark-hurts" aria-hidden="true">&cross;</span>
            {item}
          </li>
        ))
      }
    </ul>
  </section>
</div>

<style>
  .when-matrix {
    display: grid;
    gap: 1rem;
    margin-block: 1.4rem;
  }

  section {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.9rem 1.05rem;
  }

  .matrix-label {
    margin: 0 0 0.55rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .label-helps {
    color: var(--tk-green);
  }

  .label-hurts {
    color: var(--tk-red);
  }

  ul {
    display: grid;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .mark {
    font-weight: 700;
  }

  .mark-helps {
    color: var(--tk-green);
  }

  .mark-hurts {
    color: var(--tk-red);
  }

  @media (min-width: 720px) {
    .when-matrix {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
