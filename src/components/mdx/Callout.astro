---
interface Props {
  type?: "note" | "insight" | "warning" | "question";
  title?: string;
}
const { type = "note", title = "Note" } = Astro.props;
---

<aside class={`callout callout-${type}`}>
  <p class="callout-label">{title}</p>
  <slot />
</aside>

<style>
  .callout {
    border-left: 2px solid var(--accent);
    background: color-mix(in oklab, var(--accent) 5%, transparent);
    margin-block: 1.4rem;
    padding: 0.9rem 1.2rem;
  }

  .callout-warning,
  .callout-question {
    border-left-color: var(--accent-warm);
    background: color-mix(in oklab, var(--accent-warm) 5%, transparent);
  }

  .callout-label {
    margin: 0 0 0.35rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .callout :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout :global(p) {
    margin-block: 0.5rem;
  }
</style>
