---
interface MetaItem {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  items: MetaItem[];
}

const { items } = Astro.props;
---

<aside class="article-meta" aria-label="Article metadata">
  <dl>
    {
      items.map((item) => (
        <div class="meta-row">
          <dt>{item.label}</dt>
          <dd>
            {
              item.href ? (
                <a href={item.href} rel="noopener noreferrer" target="_blank">{item.value} &nearr;</a>
              ) : (
                item.value
              )
            }
          </dd>
        </div>
      ))
    }
  </dl>
</aside>

<style>
  dl {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .meta-row {
    display: grid;
    gap: 0.2rem;
  }

  dt {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
</style>
