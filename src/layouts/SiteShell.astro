---
import "../styles/global.css";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { site } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "zh-CN";
}

const { title = site.title, description = site.description, lang = "en" } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const base = import.meta.env.BASE_URL;
const href = (pathname = "") => `${base}${pathname.replace(/^\/+/, "")}`;
const canonical = new URL(Astro.url.pathname, Astro.site);

const currentPath = Astro.url.pathname;
const isActive = (pathname: string) => currentPath.startsWith(href(pathname));

const navItems = [
  { label: "Course Notes", pathname: "course-notes/" },
  { label: "Paper Reading", pathname: "paper-reading/" },
  { label: "About", pathname: "about/" }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="alternate" type="application/rss+xml" href={href("rss.xml")} title={site.title} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        let storedTheme;

        try {
          storedTheme = window.localStorage?.getItem("theme");
        } catch {
          storedTheme = undefined;
        }

        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        root.dataset.theme = storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : prefersDark
            ? "dark"
            : "light";
      })();
    </script>
  </head>
  <body>
    <a class="skip-link no-print" href="#main">Skip to content</a>
    <header class="site-header no-print">
      <nav class="container nav" aria-label="Primary navigation">
        <a class="brand" href={href()} aria-label={`${site.name} home`}>
          {site.name}
        </a>
        <div class="nav-links">
          {
            navItems.map((item) => (
              <a href={href(item.pathname)} aria-current={isActive(item.pathname) ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
          <ThemeToggle />
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="footer no-print">
      <div class="container footer-grid">
        <p>&copy; {new Date().getFullYear()} {site.name} · {site.secondaryName}</p>
        <p class="colophon">
          <a href={href("rss.xml")}>RSS</a>
          <span aria-hidden="true">·</span>
          <a href="https://github.com/ryanw0608" rel="noopener noreferrer">GitHub</a>
          <span aria-hidden="true">·</span>
          <span>Set in STIX Two Text · Built with Astro</span>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 20;
    transform: translateY(-300%);
    border: 1px solid var(--line-strong);
    background: var(--paper);
    padding: 0.5rem 0.75rem;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--paper) 92%, transparent);
    backdrop-filter: blur(10px);
  }

  .nav {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 560;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    column-gap: 1.4rem;
    row-gap: 0.25rem;
  }

  .nav-links a {
    position: relative;
    color: var(--muted);
    font-size: 0.9rem;
    padding-block: 0.35rem;
    text-decoration: none;
    transition: color 140ms ease;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .nav-links a[aria-current="page"] {
    color: var(--ink);
  }

  .nav-links a[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    border-bottom: 2px solid var(--accent);
  }

  main {
    min-height: calc(100vh - 12rem);
  }

  .footer {
    margin-top: 5rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    padding-block: 1.6rem 2.2rem;
  }

  .footer-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 2rem;
  }

  .footer p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .colophon {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition: color 140ms ease, border-color 140ms ease;
  }

  .footer a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav {
      flex-wrap: wrap;
      padding-block: 0.7rem;
    }

    .nav-links {
      justify-content: flex-start;
      column-gap: 1rem;
    }
  }
</style>
