---
/*
 * Hero showpiece: a live diagram of speculative decoding.
 * Draft tokens stream in ghosted; a verify bar sweeps them in parallel;
 * the matching prefix is accepted, the first mismatch is rejected and
 * corrected. Canvas 2D, 30fps, paused off-screen, static under
 * reduced-motion and without JavaScript.
 */
---

<figure class="token-stream rise" style="--rise-order: 1;" data-token-stream>
  <p class="prompt-line" aria-hidden="true">
    <span class="prompt">$</span> <span class="cmd">./spec-decode --visualize</span>
  </p>
  <div class="ts-frame">
    <canvas data-ts-canvas hidden aria-hidden="true"></canvas>
    <pre class="ts-fallback" data-ts-fallback aria-hidden="true"><span class="tk-ok">spec</span> <span class="tk-ok">ulat</span> <span class="tk-ok">ive</span> <span class="tk-acc">dec</span> <span class="tk-acc">oding</span> <span class="tk-rej">gemm</span> <span class="tk-draft">kv</span> <span class="tk-draft">cache</span><span class="ts-caret"></span></pre>
  </div>
  <figcaption class="ts-legend">
    <span class="legend-item"><span class="swatch sw-draft" aria-hidden="true"></span>draft</span>
    <span class="legend-item"><span class="swatch sw-accept" aria-hidden="true"></span>accepted</span>
    <span class="legend-item"><span class="swatch sw-reject" aria-hidden="true"></span>rejected</span>
    <span class="legend-note">
      speculative decoding — draft tokens verified in parallel, matching prefix accepted
    </span>
  </figcaption>
</figure>

<script>
  const root = document.querySelector("[data-token-stream]");
  const canvas = root?.querySelector<HTMLCanvasElement>("[data-ts-canvas]");
  const fallback = root?.querySelector<HTMLElement>("[data-ts-fallback]");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && canvas && fallback && !reduced) {
    const ctx = canvas.getContext("2d");

    if (ctx) {
      canvas.hidden = false;
      fallback.hidden = true;

      const POOL = [
        "spec", "ulat", "ive", "dec", "oding", "kv", "cache", "attn", "soft", "max",
        "batch", "fuse", "gemm", "tok", "gen", "p95", "lat", "tput", "q", "k", "v"
      ];

      let palette = readPalette();
      new MutationObserver(() => {
        palette = readPalette();
      }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

      function readPalette() {
        const style = getComputedStyle(document.documentElement);
        const get = (name: string) => style.getPropertyValue(name).trim();
        return {
          fg: get("--fg"),
          faint: get("--faint"),
          line: get("--line"),
          surface: get("--surface"),
          accent: get("--accent"),
          draft: get("--tk-orange"),
          accept: get("--tk-green"),
          reject: get("--tk-red")
        };
      }

      interface Token {
        text: string;
        state: "committed" | "draft" | "accepted" | "rejected" | "corrected";
        alpha: number;
        jitter: number;
      }

      const FONT_SIZE = 13;
      const CELL_H = 26;
      const PAD_X = 9;
      const GAP = 8;

      let cssW = 0;
      let cssH = 0;
      let tokens: Token[] = [];
      let phase: "draft" | "verify" | "resolve" | "commit" = "draft";
      let phaseT = 0;
      let draftTarget = 4;
      let draftStart = 0;
      let acceptCount = 0;
      let sweep = 0;
      let scrollX = 0;
      let scrollFrom = 0;
      let scrollTo = 0;

      const rand = (lo: number, hi: number) => lo + Math.floor(Math.random() * (hi - lo + 1));
      const pick = () => POOL[Math.floor(Math.random() * POOL.length)];

      const resize = () => {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        cssW = canvas.clientWidth;
        cssH = canvas.clientHeight;
        canvas.width = Math.round(cssW * dpr);
        canvas.height = Math.round(cssH * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.font = `500 ${FONT_SIZE}px "JetBrains Mono Variable", Consolas, monospace`;
        ctx.textBaseline = "middle";
      };

      let resizeTimer = 0;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(resize, 150);
      });

      const tokenWidth = (token: Token) => ctx.measureText(token.text).width + PAD_X * 2;

      const seed = () => {
        tokens = Array.from({ length: 3 }, () => ({
          text: pick(),
          state: "committed" as const,
          alpha: 1,
          jitter: 0
        }));
        phase = "draft";
        phaseT = 0;
        draftTarget = rand(4, 6);
        draftStart = tokens.length;
        scrollX = 0;
      };

      const update = (dt: number) => {
        phaseT += dt;

        if (phase === "draft") {
          const wanted = Math.min(draftTarget, Math.floor(phaseT / 100));
          while (tokens.length - draftStart < wanted) {
            tokens.push({ text: pick(), state: "draft", alpha: 0.55, jitter: 0 });
          }
          if (tokens.length - draftStart >= draftTarget && phaseT > draftTarget * 100 + 160) {
            phase = "verify";
            phaseT = 0;
            sweep = 0;
          }
        } else if (phase === "verify") {
          sweep = Math.min(1, phaseT / 180);
          if (sweep >= 1 && phaseT > 300) {
            acceptCount = Math.random() < 0.25 ? draftTarget : rand(1, draftTarget - 1);
            tokens.forEach((token, index) => {
              if (token.state !== "draft") return;
              const offset = index - draftStart;
              if (offset < acceptCount) {
                token.state = "accepted";
                token.alpha = 1;
              } else if (offset === acceptCount) {
                token.state = "rejected";
                token.alpha = 1;
              }
            });
            phase = "resolve";
            phaseT = 0;
          }
        } else if (phase === "resolve") {
          tokens.forEach((token, index) => {
            if (token.state === "rejected") {
              token.jitter = phaseT < 200 ? Math.sin(phaseT / 14) * 2 : 0;
              token.alpha = Math.max(0, 1 - Math.max(0, phaseT - 220) / 180);
            }
            if (token.state === "draft" && index > draftStart + acceptCount) {
              token.alpha = Math.max(0, 0.55 - phaseT / 300);
            }
          });

          if (phaseT > 420) {
            tokens = tokens.filter((token) => token.state !== "rejected" && token.state !== "draft");
            tokens.forEach((token) => {
              if (token.state === "accepted") token.state = "committed";
            });
            if (acceptCount < draftTarget) {
              tokens.push({ text: pick(), state: "corrected", alpha: 1, jitter: 0 });
            }
            phase = "commit";
            phaseT = 0;
            scrollFrom = scrollX;
            scrollTo = computeOverflow();
          }
        } else if (phase === "commit") {
          const t = Math.min(1, phaseT / 300);
          scrollX = scrollFrom + (scrollTo - scrollFrom) * (1 - Math.pow(1 - t, 3));
          if (t >= 1) {
            tokens.forEach((token) => {
              if (token.state === "corrected") token.state = "committed";
            });
            if (tokens.length > 24) tokens = tokens.slice(tokens.length - 12);
            phase = "draft";
            phaseT = 0;
            draftStart = tokens.length;
            draftTarget = rand(4, 6);
            scrollX = computeOverflow();
            scrollFrom = scrollX;
          }
        }
      };

      const computeOverflow = () => {
        const total = tokens.reduce((sum, token) => sum + tokenWidth(token) + GAP, 0);
        return Math.max(0, total - cssW * 0.82);
      };

      const draw = () => {
        ctx.clearRect(0, 0, cssW, cssH);
        const y = cssH / 2;
        let x = 16 - scrollX;
        let sweepFrom = 0;
        let sweepTo = 0;

        tokens.forEach((token, index) => {
          const w = tokenWidth(token);

          if (index === draftStart) sweepFrom = x;
          if (index >= draftStart) sweepTo = x + w;

          if (x + w > -20 && x < cssW + 20 && token.alpha > 0.01) {
            ctx.globalAlpha = token.alpha;
            const color =
              token.state === "draft"
                ? palette.draft
                : token.state === "accepted"
                  ? palette.accept
                  : token.state === "rejected"
                    ? palette.reject
                    : token.state === "corrected"
                      ? palette.accent
                      : palette.fg;

            ctx.fillStyle = palette.surface;
            ctx.strokeStyle = token.state === "committed" ? palette.line : color;
            ctx.beginPath();
            ctx.roundRect(x, y - CELL_H / 2 + token.jitter, w, CELL_H, 4);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = color;
            ctx.fillText(token.text, x + PAD_X, y + token.jitter + 0.5);
            ctx.globalAlpha = 1;
          }

          x += w + GAP;
        });

        if (phase === "verify" && sweepTo > sweepFrom) {
          const barX = sweepFrom + (sweepTo - sweepFrom) * sweep;
          ctx.fillStyle = palette.accent;
          ctx.fillRect(barX, y - CELL_H / 2 - 6, 2, CELL_H + 12);
        }

        if (phase === "draft" || phase === "commit") {
          ctx.fillStyle = palette.accent;
          ctx.fillRect(x, y - CELL_H / 2 + 4, 7, CELL_H - 8);
        }
      };

      let rafId = 0;
      let last = 0;
      let running = false;

      const frame = (now: number) => {
        if (!running) return;
        rafId = requestAnimationFrame(frame);
        if (now - last < 33) return;
        const dt = Math.min(100, now - last);
        last = now;
        update(dt);
        draw();
      };

      const start = () => {
        if (running) return;
        running = true;
        last = performance.now();
        rafId = requestAnimationFrame(frame);
      };

      const stop = () => {
        running = false;
        cancelAnimationFrame(rafId);
      };

      new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => (entry.isIntersecting ? start() : stop()));
        },
        { threshold: 0.05 }
      ).observe(canvas);

      const boot = () => {
        resize();
        seed();
        draw();
      };

      if ("requestIdleCallback" in window) {
        requestIdleCallback(boot, { timeout: 1200 });
      } else {
        setTimeout(boot, 200);
      }
    }
  }
</script>

<style>
  .token-stream {
    display: grid;
    gap: 1.1rem;
    margin: 0;
  }

  .ts-frame {
    position: relative;
    height: clamp(120px, 16vw, 160px);
    border: 1px solid var(--line);
    border-radius: 6px;
    background: color-mix(in oklab, var(--surface) 55%, var(--bg));
    overflow: hidden;
  }

  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .ts-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    padding-inline: 1rem;
    font-size: 0.85rem;
    overflow: hidden;
    white-space: nowrap;
  }

  .tk-ok {
    color: var(--fg);
  }

  .tk-acc {
    color: var(--tk-green);
  }

  .tk-rej {
    color: var(--tk-red);
    text-decoration: line-through;
  }

  .tk-draft {
    color: var(--tk-orange);
    opacity: 0.6;
  }

  .ts-caret {
    display: inline-block;
    width: 0.5em;
    height: 1em;
    margin-left: 0.3em;
    vertical-align: text-bottom;
    background: var(--accent);
  }

  .ts-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.2rem;
    color: var(--faint);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .swatch {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 2px;
  }

  .sw-draft {
    background: var(--tk-orange);
  }

  .sw-accept {
    background: var(--tk-green);
  }

  .sw-reject {
    background: var(--tk-red);
  }

  .legend-note {
    color: var(--faint);
  }

  @media (max-width: 640px) {
    .legend-note {
      flex-basis: 100%;
    }
  }
</style>
