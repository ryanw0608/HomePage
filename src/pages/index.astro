---
import { getCollection } from "astro:content";

import LearningMapPreview from "@/components/LearningMapPreview.astro";
import NoteCard from "@/components/NoteCard.astro";
import { profile } from "@/data/profile";
import { courses } from "@/data/taxonomy";
import SiteShell from "@/layouts/SiteShell.astro";
import { byDateDesc, entryPath, publicEntries } from "@/lib/content";

const latestCourseNotes = publicEntries(await getCollection("course-notes")).sort(byDateDesc).slice(0, 2);
const latestPaperReadings = publicEntries(await getCollection("paper-reading")).sort(byDateDesc).slice(0, 2);
const latestWriting = [
  ...latestCourseNotes.map((entry) => ({
    collection: "course-notes" as const,
    entry,
    meta: `${courses[entry.data.course].label} · ${entry.data.date.toISOString().slice(0, 10)}`
  })),
  ...latestPaperReadings.map((entry) => ({
    collection: "paper-reading" as const,
    entry,
    meta: `${entry.data.paperTitle} · ${entry.data.year} · ${entry.data.status}`
  }))
];
---

<SiteShell title="Yongzhe Wang" description="Academic homepage, course notes, and paper reading notes by Yongzhe Wang.">
  <section class="container home-shell" aria-labelledby="home-title">
    <div class="hero-panel">
      <div class="identity">
        <p class="secondary-name">{profile.secondaryName}</p>
        <h1 id="home-title">{profile.name}</h1>
        <p class="summary">{profile.summary}</p>
        <p class="engineering-line">
          Former frontend engineer building a long-lived academic knowledge base for course notes, structured paper reading, and research practice.
        </p>
      </div>

      <aside class="status-board" aria-label="Academic command center status">
        <div>
          <span class="status-label">Mode</span>
          <strong>Academic command center</strong>
        </div>
        <div>
          <span class="status-label">Base</span>
          <strong>{profile.location}</strong>
        </div>
        <div>
          <span class="status-label">Writing streams</span>
          <strong>Courses + papers</strong>
        </div>
      </aside>
    </div>

    <section class="focus-section" aria-labelledby="focus-title">
      <div class="section-heading">
        <p class="eyebrow">Current stack</p>
        <h2 id="focus-title">Current Focus</h2>
      </div>
      <div class="focus-grid">
        {
          profile.currentFocus.map((focus, index) => (
            <article class="focus-card">
              <span class="focus-index">{String(index + 1).padStart(2, "0")}</span>
              <h3>{focus.label}</h3>
              <p>{focus.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="writing-section" aria-labelledby="writing-title">
      <div class="section-heading">
        <p class="eyebrow">Recent output</p>
        <h2 id="writing-title">Latest Writing</h2>
      </div>
      <div class="writing-grid">
        {
          latestWriting.map(({ collection, entry, meta }) => (
            <NoteCard
              href={entryPath(collection, entry)}
              title={entry.data.title}
              summary={entry.data.summary}
              meta={meta}
              tags={entry.data.tags}
            />
          ))
        }
      </div>
    </section>

    <LearningMapPreview />
  </section>
</SiteShell>

<style>
  .home-shell {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(2rem, 5vw, 4rem) 1rem;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: 1rem;
    align-items: stretch;
  }

  .identity,
  .status-board,
  .focus-card {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
  }

  .identity {
    display: grid;
    align-content: end;
    min-height: 380px;
    padding: clamp(1.25rem, 4vw, 2.25rem);
  }

  .secondary-name,
  h1,
  .summary,
  .engineering-line,
  .eyebrow,
  h2,
  h3,
  .focus-card p {
    margin: 0;
  }

  .secondary-name,
  .eyebrow,
  .status-label {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin-top: 0.55rem;
    max-width: 11ch;
    font-size: clamp(3.3rem, 10vw, 7.4rem);
    line-height: 0.9;
  }

  .summary {
    max-width: 65ch;
    margin-top: 1.35rem;
    color: var(--text);
    font-size: clamp(1.12rem, 2vw, 1.35rem);
    line-height: 1.55;
  }

  .engineering-line {
    max-width: 72ch;
    margin-top: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .status-board {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    min-height: 380px;
  }

  .status-board div {
    display: grid;
    align-content: center;
    gap: 0.4rem;
    border-bottom: 1px solid var(--border);
    padding: 1.25rem;
  }

  .status-board div:last-child {
    border-bottom: 0;
  }

  .status-board strong {
    font-size: clamp(1.25rem, 2.5vw, 1.7rem);
    line-height: 1.15;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .focus-card {
    display: grid;
    min-height: 220px;
    align-content: space-between;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .focus-index {
    color: color-mix(in oklab, var(--accent-2) 82%, var(--text));
    font-size: 0.9rem;
    font-weight: 850;
  }

  .focus-card h3 {
    font-size: 1.35rem;
    line-height: 1.16;
  }

  .focus-card p {
    color: var(--muted);
    line-height: 1.6;
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 850px) {
    .hero-panel,
    .focus-grid,
    .writing-grid {
      grid-template-columns: 1fr;
    }

    .identity,
    .status-board {
      min-height: auto;
    }

    .status-board {
      grid-template-rows: none;
    }
  }

  @media (max-width: 560px) {
    .section-heading {
      display: grid;
      align-items: start;
    }

    h1 {
      font-size: clamp(3rem, 18vw, 4.6rem);
    }
  }
</style>
