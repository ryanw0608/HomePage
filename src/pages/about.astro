---
import { profile } from "@/data/profile";
import SiteShell from "@/layouts/SiteShell.astro";
---

<SiteShell title="About" description="About Yongzhe Wang.">
  <section class="container about-page" aria-labelledby="about-title">
    <p class="prompt-line" aria-hidden="true"><span class="prompt">$</span> <span class="cmd">cat about.md</span></p>
    <div class="article-body about-body">
      <h1 id="about-title">{profile.displayName}</h1>
      <p class="about-meta">{profile.secondaryName} · MSc computer science · University of Sydney · {profile.location}</p>

      <h2>Profile</h2>
      <p>
        I am a master's student in computer science at the University of Sydney and a member of the{" "}
        <a href={profile.lab.href} rel="noopener noreferrer">{profile.lab.name}</a>, advised by{" "}
        <a href={profile.advisors[0].href} rel="noopener noreferrer">{profile.advisors[0].name}</a> and{" "}
        <a href={profile.advisors[1].href} rel="noopener noreferrer">{profile.advisors[1].name}</a>.
      </p>
      <p>
        My research sits around machine learning systems: efficient LLM inference (speculative decoding and
        system-level serving optimization), agentic and multi-agent systems (tool use, planning, and reliable
        workflows), and AI for condensed matter physics (learned models for physical simulation, materials, and
        scientific discovery).
      </p>

      <h2>Education</h2>
      <ul>
        {
          profile.education.map((item) => (
            <li>
              <strong>{item.degree}</strong> — {item.school}
            </li>
          ))
        }
      </ul>

      <h2>Practice</h2>
      <p>
        This site is a public workspace for making the work legible: what I am learning, what I am reading, and
        how ideas connect over time. Course notes are written as reusable explanations rather than one-off
        summaries. Paper reading notes capture the problem setting, core method, strengths, limitations, and
        follow-up questions so each reading session leaves a trail.
      </p>

      <h2>Links</h2>
      <ul>
        {
          profile.links.map((link) => (
            <li>
              <a href={link.href} rel="noopener noreferrer">{link.label}</a>
            </li>
          ))
        }
        <li>
          <a href={profile.lab.href} rel="noopener noreferrer">{profile.lab.shortName}</a>
        </li>
        {
          profile.advisors.map((advisor) => (
            <li>
              <a href={advisor.href} rel="noopener noreferrer">{advisor.name}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</SiteShell>

<style>
  .about-page {
    display: grid;
    gap: 1.4rem;
    padding-block: clamp(2.5rem, 6vw, 4rem) 1rem;
  }

  .about-body h1 {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .about-body h1::before {
    content: "# " / "";
    color: var(--accent);
    font-weight: 600;
  }

  .about-meta {
    color: var(--faint);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }
</style>
