---
import { getCollection, render } from "astro:content";

import { mdxComponents } from "@/components/mdx";
import ArticleLayout from "@/layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const digests = await getCollection("digest");

  return digests.map((digest) => ({
    params: { slug: digest.id },
    props: { digest }
  }));
}

const { digest } = Astro.props;
const { Content, headings } = await render(digest);
---

<ArticleLayout
  title={digest.data.title}
  description={digest.data.summary}
  headings={headings}
  kicker={`Agent digest${digest.data.model ? ` · generated by ${digest.data.model}` : ""}`}
  meta={[
    { label: "Date", value: digest.data.date.toISOString().slice(0, 10) },
    ...(digest.data.model ? [{ label: "Model", value: digest.data.model }] : []),
    { label: "Source", value: "committed notes" }
  ]}
  backHref={`${import.meta.env.BASE_URL}digest/`}
  backLabel="Digest"
>
  <Content components={mdxComponents} />
</ArticleLayout>
