---
import { learningMapNodes } from "@/data/learning-map";
---

<section class="rail rise map-section" aria-labelledby="learning-map-title" style="--rise-order: 3;">
  <p class="rail-label" id="learning-map-title">Topics</p>
  <div class="rail-body">
    <p class="map-description">
      Topics this notebook is accumulating around. The list is short on purpose: it grows only when new notes
      connect to it.
    </p>
    <ul class="node-list">
      {
        learningMapNodes.map((node) => (
          <li>
            <span class="node-head">
              <span class="node-label">{node.label}</span>
              <span class="node-type">{node.type}</span>
            </span>
            {node.summary && <span class="node-summary">{node.summary}</span>}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .map-description {
    margin: 0.2rem 0 1.4rem;
    max-width: 55ch;
    color: var(--muted);
    line-height: 1.62;
  }

  .node-list {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .node-list li {
    display: grid;
    gap: 0.3rem;
    border-top: 1px solid var(--line);
    padding-block: 0.95rem;
  }

  .node-head {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }

  .node-label {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 540;
    letter-spacing: -0.01em;
  }

  .node-type {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .node-summary {
    max-width: 60ch;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
