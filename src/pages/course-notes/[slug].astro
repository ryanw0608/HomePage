---
import { getCollection, render } from "astro:content";

import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { courses, tags } from "@/data/taxonomy";
import { entrySlug, publicEntries, readingTime } from "@/lib/content";
import { htmlLang } from "@/lib/site";

export async function getStaticPaths() {
  const notes = publicEntries(await getCollection("course-notes"));

  return notes.map((note) => ({
    params: { slug: entrySlug(note) },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);
const lang = htmlLang(note.data.language, note.data.primaryLanguage);
const tagLabels = note.data.tags.map((tag) => tags[tag].label).join(", ");
---

<ArticleLayout
  title={note.data.title}
  description={note.data.description}
  lang={lang}
  headings={headings}
  kicker={`Course note · ${courses[note.data.course].label}`}
  readingMinutes={readingTime(note.body ?? "")}
  meta={[
    { label: "Date", value: note.data.date.toISOString().slice(0, 10) },
    ...(note.data.updated ? [{ label: "Updated", value: note.data.updated.toISOString().slice(0, 10) }] : []),
    { label: "Status", value: note.data.status },
    ...(tagLabels ? [{ label: "Tags", value: tagLabels }] : [])
  ]}
  backHref={`${import.meta.env.BASE_URL}course-notes/`}
  backLabel="Course notes"
>
  <Content />
</ArticleLayout>
