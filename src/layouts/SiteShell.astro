---
import "../styles/global.css";
import { getCollection } from "astro:content";

import CommandPalette from "@/components/CommandPalette.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { publicEntries } from "@/lib/content";
import { site } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "zh-CN";
}

const { title = site.title, description = site.description, lang = "en" } = Astro.props;
const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const base = import.meta.env.BASE_URL;
const href = (pathname = "") => `${base}${pathname.replace(/^\/+/, "")}`;
const canonical = new URL(Astro.url.pathname, Astro.site);

// Prompt-path breadcrumb: ~ is home; detail pages read as the .md file they are.
const relPath = Astro.url.pathname.replace(base, "").replace(/\/+$/, "");
const segments = relPath ? relPath.split("/") : [];
const crumbs = segments.map((segment, index) => ({
  label: index === segments.length - 1 && index > 0 ? `${segment}.md` : segment,
  href: `${base}${segments.slice(0, index + 1).join("/")}/`,
  isCurrent: index === segments.length - 1
}));

const currentPath = Astro.url.pathname;
const isActive = (pathname: string) => currentPath.startsWith(href(pathname));
const navItems = [
  { label: "course-notes", pathname: "course-notes/" },
  { label: "paper-reading", pathname: "paper-reading/" },
  { label: "about", pathname: "about/" }
];

const noteCount = publicEntries(await getCollection("course-notes")).length;
const paperCount = publicEntries(await getCollection("paper-reading")).length;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="alternate" type="application/rss+xml" href={href("rss.xml")} title={site.title} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        let storedTheme;

        try {
          storedTheme = window.localStorage?.getItem("theme");
        } catch {
          storedTheme = undefined;
        }

        // Dark-first: dark is the designed default; light is an explicit choice.
        root.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "dark";
      })();
    </script>
  </head>
  <body>
    <a class="skip-link no-print" href="#main">Skip to content</a>
    <header class="term-bar no-print">
      <nav class="container bar-inner" aria-label="Primary navigation">
        <p class="crumb" aria-label="Current path">
          <a class="host" href={href()} aria-label={`${site.name} home`}>yongzhe@wang</a><span
            class="sep">:</span><a class="tilde" href={href()} aria-hidden="true" tabindex="-1">~</a>{
            crumbs.map((crumb) => (
              <>
                <span class="sep">/</span>
                {crumb.isCurrent ? (
                  <span class="crumb-current" aria-current="page">{crumb.label}</span>
                ) : (
                  <a href={crumb.href}>{crumb.label}</a>
                )}
              </>
            ))
          }
        </p>
        <div class="nav-links">
          {
            navItems.map((item) => (
              <a href={href(item.pathname)} aria-current={isActive(item.pathname) ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="status-bar no-print">
      <div class="container status-inner">
        <p class="status-left">
          <span class="status-ok" aria-hidden="true">●</span>
          &copy; {new Date().getFullYear()} {site.name}
          <span class="status-counts">· {noteCount} {noteCount === 1 ? "note" : "notes"} · {paperCount}
            {paperCount === 1 ? "reading" : "readings"}</span>
        </p>
        <div class="status-right">
          <a href={href("rss.xml")}>rss</a>
          <a href="https://github.com/ryanw0608" rel="noopener noreferrer">github</a>
          <button class="k-chip" type="button" data-palette-open hidden aria-label="Open command palette">
            &#8984;K
          </button>
          <ThemeToggle />
        </div>
      </div>
    </footer>
    <CommandPalette />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 80;
    transform: translateY(-300%);
    border: 1px solid var(--edge);
    background: var(--surface);
    padding: 0.5rem 0.75rem;
    color: var(--fg);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .term-bar {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg) 90%, transparent);
    backdrop-filter: blur(10px);
  }

  .bar-inner {
    display: flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .crumb {
    margin: 0;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.82rem;
  }

  .crumb a {
    color: var(--muted);
    text-decoration: none;
    transition: color 140ms ease;
  }

  .crumb a:hover {
    color: var(--accent);
  }

  .host {
    color: var(--accent) !important;
    font-weight: 600;
  }

  .host:hover {
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .sep {
    color: var(--faint);
  }

  .tilde {
    color: var(--fg) !important;
  }

  .crumb-current {
    color: var(--fg);
    font-weight: 500;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    column-gap: 1.25rem;
    row-gap: 0.25rem;
  }

  .nav-links a {
    position: relative;
    color: var(--muted);
    font-size: 0.82rem;
    padding-block: 0.35rem;
    text-decoration: none;
    transition: color 140ms ease;
  }

  .nav-links a::before {
    content: "./" / "";
    color: var(--faint);
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .nav-links a[aria-current="page"] {
    color: var(--fg);
  }

  .nav-links a[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    border-bottom: 2px solid var(--accent);
  }

  main {
    min-height: calc(100vh - 10rem);
    padding-bottom: 4.5rem;
  }

  .status-bar {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 40;
    border-top: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
  }

  .status-inner {
    display: flex;
    min-height: 2.1rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .status-left {
    margin: 0;
    color: var(--faint);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-ok {
    color: var(--accent);
    margin-right: 0.2rem;
  }

  .status-right {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-shrink: 0;
  }

  .status-right a {
    color: var(--faint);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 140ms ease;
  }

  .status-right a:hover {
    color: var(--accent);
  }

  .k-chip {
    border: 1px solid var(--edge);
    border-radius: 4px;
    background: transparent;
    color: var(--faint);
    font-family: inherit;
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    padding: 0.18rem 0.45rem;
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease;
  }

  .k-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .bar-inner {
      flex-wrap: wrap;
      padding-block: 0.55rem;
    }

    .nav-links {
      justify-content: flex-start;
      column-gap: 1rem;
    }

    .status-counts {
      display: none;
    }
  }
</style>
