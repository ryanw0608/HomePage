---
import "../../styles/global.css";

import App from "@/studio/App";

// Studio: private editor tool. noindex + excluded from the sitemap
// (astro.config.mjs); writes are gated by GitHub collaborator permissions,
// so shipping the static shell publicly is safe by design.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Studio | Yongzhe Wang</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <script is:inline>
      (() => {
        let storedTheme;
        try {
          storedTheme = window.localStorage?.getItem("yw-theme");
        } catch {
          storedTheme = undefined;
        }
        document.documentElement.dataset.theme =
          storedTheme === "light" || storedTheme === "dark" ? storedTheme : "dark";
      })();
    </script>
  </head>
  <body>
    <App client:only="react" />
    <noscript>
      <p style="padding: 2rem; font-family: monospace;">
        Studio is a client-side editor and needs JavaScript. The published site itself works
        without it.
      </p>
    </noscript>
  </body>
</html>
