---
import { tags as tagDefinitions } from "@/data/taxonomy";

interface Props {
  href: string;
  title: string;
  summary: string;
  datestamp: string;
  annotation?: string;
  tags?: string[];
  minutes?: number;
  lang?: "zh" | "en" | "mixed";
  status?: string;
  rating?: number;
  headingLevel?: "h2" | "h3";
}

const {
  href,
  title,
  summary,
  datestamp,
  annotation,
  tags = [],
  minutes,
  lang,
  status,
  rating,
  headingLevel = "h2"
} = Astro.props;
const HeadingTag = headingLevel;
const displayTags = tags.map(
  (tag) => tagDefinitions[tag as keyof typeof tagDefinitions]?.label.toLowerCase().replace(/\s+/g, "-") ?? tag
);
const langLabel = lang === "zh" ? "中" : lang === "mixed" ? "EN·中" : lang === "en" ? "EN" : undefined;
const stars = rating ? "●".repeat(rating) + "○".repeat(5 - rating) : undefined;

// Status tone: color families shared with the article verdict chips.
const statusTone: Record<string, string> = {
  reviewed: "green",
  reading: "yellow",
  skimmed: "blue",
  revisit: "magenta",
  queued: "comment",
  active: "yellow",
  complete: "green",
  evergreen: "cyan"
};
const tone = status ? statusTone[status] ?? "comment" : undefined;
---

<article class="entry-row">
  <p class="entry-date">{datestamp}</p>
  <div class="entry-main">
    <HeadingTag class="entry-title">
      <a href={href}>{title}</a>
    </HeadingTag>
    {annotation && <p class="entry-annotation">{annotation}</p>}
    <p class="entry-summary">{summary}</p>
    <p class="entry-data" aria-label="Language, status, tags, and reading time">
      {langLabel && <span class="entry-lang">{langLabel}</span>}
      {status && tone && <span class:list={["entry-status", `tone-${tone}`]}>{status}</span>}
      {displayTags.map((tag) => <span class="entry-tag">#{tag}</span>)}
      {minutes && <span class="entry-minutes">~{minutes} min</span>}
      {
        stars && (
          <span class="entry-rating">
            <span aria-hidden="true">{stars}</span>
            <span class="sr-only">rated {rating} out of 5</span>
          </span>
        )
      }
    </p>
  </div>
</article>

<style>
  .entry-row {
    display: grid;
    gap: 0.3rem;
    border-top: 1px solid var(--line);
    padding-block: 1.15rem;
  }

  .entry-row:first-of-type {
    border-top: 0;
    padding-top: 0.15rem;
  }

  .entry-date {
    margin: 0;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }

  .entry-main {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
  }

  .entry-title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: -0.005em;
    line-height: 1.4;
  }

  .entry-title a {
    color: var(--fg);
    text-decoration: none;
    transition: color 140ms ease;
  }

  .entry-title a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.25em;
  }

  .entry-annotation {
    margin: 0;
    color: var(--faint);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .entry-summary {
    margin: 0;
    max-width: 64ch;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .entry-data {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.3rem 0.85rem;
    margin: 0.15rem 0 0;
    font-size: 0.74rem;
    letter-spacing: 0.02em;
  }

  .entry-lang {
    color: var(--tk-cyan);
    border: 1px solid color-mix(in oklab, var(--tk-cyan) 45%, transparent);
    border-radius: 3px;
    font-size: 0.66rem;
    padding: 0.05rem 0.35rem;
  }

  .entry-status {
    border: 1px solid currentColor;
    border-radius: 3px;
    font-size: 0.66rem;
    padding: 0.05rem 0.35rem;
  }

  .tone-green {
    color: var(--tk-green);
  }

  .tone-yellow {
    color: var(--tk-yellow);
  }

  .tone-blue {
    color: var(--tk-blue);
  }

  .tone-magenta {
    color: var(--tk-magenta);
  }

  .tone-cyan {
    color: var(--tk-cyan);
  }

  .tone-comment {
    color: var(--tk-comment);
  }

  .entry-tag {
    color: var(--tk-cyan);
  }

  .entry-minutes {
    color: var(--faint);
  }

  .entry-rating {
    color: var(--tk-yellow);
    letter-spacing: 0.12em;
  }

  @media (min-width: 640px) {
    .entry-row {
      grid-template-columns: 6.5rem minmax(0, 1fr);
      column-gap: 1.5rem;
    }

    .entry-date {
      padding-top: 0.14rem;
    }
  }
</style>
