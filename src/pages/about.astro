---
import { profile } from "@/data/profile";
import SiteShell from "@/layouts/SiteShell.astro";
---

<SiteShell title="About" description="About Yongzhe Wang.">
  <section class="container about-page" aria-labelledby="about-title">
    <header class="rail">
      <p class="rail-label">About</p>
      <div class="rail-body">
        <h1 id="about-title" class="title-serif">{profile.name}</h1>
        <p class="hero-meta">{profile.secondaryName} · {profile.role} · {profile.location}</p>
      </div>
    </header>

    <section class="rail" aria-labelledby="profile-label">
      <p class="rail-label" id="profile-label">Profile</p>
      <div class="rail-body about-prose">
        <p>
          I am transitioning from frontend engineering toward academic study and research practice. This site is a
          public workspace for making that transition legible: what I am learning, what I am reading, and how ideas
          connect over time.
        </p>
        <p>
          My frontend background still shapes the work. I care about durable interfaces, precise typography,
          accessible reading experiences, and static systems that can keep serving notes long after the original
          course or paper sprint is over.
        </p>
      </div>
    </section>

    <section class="rail" aria-labelledby="practice-label">
      <p class="rail-label" id="practice-label">Practice</p>
      <div class="rail-body about-prose">
        <p>
          Course notes are written as reusable explanations rather than one-off summaries. Paper reading notes
          capture the problem setting, core method, strengths, limitations, and follow-up questions so each reading
          session leaves a trail.
        </p>
        <p>
          Current interests include machine learning foundations, optimization, attention mechanisms, and the craft
          of building a long-lived academic knowledge base.
        </p>
      </div>
    </section>

    <section class="rail" aria-labelledby="links-label">
      <p class="rail-label" id="links-label">Links</p>
      <div class="rail-body">
        <ul class="link-list">
          {
            profile.links.map((link) => (
              <li>
                <a href={link.href} rel="noopener noreferrer">{link.label} &nearr;</a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </section>
</SiteShell>

<style>
  .about-page {
    display: grid;
    gap: clamp(2.25rem, 5vw, 3.5rem);
    padding-block: clamp(2.5rem, 6vw, 4.5rem) 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5.5vw, 3.2rem);
    line-height: 1.05;
  }

  .hero-meta {
    margin: 1rem 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
  }

  .about-prose {
    max-width: 41rem;
  }

  .about-prose p {
    margin: 0 0 1rem;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .about-prose p:last-child {
    margin-bottom: 0;
  }

  .link-list {
    display: grid;
    gap: 0.7rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .link-list a {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    padding-bottom: 0.1rem;
    transition: border-color 140ms ease;
  }

  .link-list a:hover {
    border-bottom-color: var(--accent);
  }
</style>
