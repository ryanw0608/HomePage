---
interface NavEntry {
  title: string;
  href: string;
}

interface Props {
  prev?: NavEntry;
  next?: NavEntry;
  position: number;
  total: number;
}
const { prev, next, position, total } = Astro.props;
---

{
  total > 1 && (
    <nav class="course-nav no-print" aria-label="Course navigation">
      <p class="nav-slot nav-prev">
        {prev && (
          <a href={prev.href}>
            <span class="nav-label">&larr; prev</span>
            <span class="nav-title">{prev.title}</span>
          </a>
        )}
      </p>
      <p class="nav-position">part {position} of {total}</p>
      <p class="nav-slot nav-next">
        {next && (
          <a href={next.href}>
            <span class="nav-label">next &rarr;</span>
            <span class="nav-title">{next.title}</span>
          </a>
        )}
      </p>
    </nav>
  )
}

<style>
  .course-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: start;
    border-top: 1px solid var(--line);
    margin-top: 2.5rem;
    padding-top: 1.1rem;
  }

  .nav-slot,
  .nav-position {
    margin: 0;
  }

  .nav-next {
    text-align: right;
  }

  .nav-position {
    color: var(--faint);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    padding-top: 0.15rem;
  }

  .nav-slot a {
    display: inline-grid;
    gap: 0.2rem;
    text-decoration: none;
  }

  .nav-label {
    color: var(--tk-blue);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .nav-title {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.4;
    transition: color 140ms ease;
  }

  .nav-slot a:hover .nav-title {
    color: var(--fg);
  }

  @media (max-width: 560px) {
    .course-nav {
      grid-template-columns: 1fr;
    }

    .nav-next {
      text-align: left;
    }

    .nav-position {
      order: -1;
    }
  }
</style>
